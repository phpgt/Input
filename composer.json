{
	"name": "phpgt/input",
	"description": "Encapsulated user input.",
	"license": "MIT",

	"require": {
		"php": ">=8.3",
		"phpgt/http": "1.*",
		"phpgt/json": "^2.1"
	},

	"require-dev": {
		"phpstan/phpstan": "^1.10",
		"phpunit/phpunit": "^10.5",
		"phpmd/phpmd": "^2.13",
		"squizlabs/php_codesniffer": "^4.0"
	},

	"autoload": {
		"psr-4": {
			"Gt\\Input\\": "./src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Gt\\Input\\Test\\": "./test/phpunit"
		}
	},

	"scripts": {
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml",
		"phpunit:coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --configuration phpunit.xml --coverage-text",
		"phpstan": "vendor/bin/phpstan analyse --level 6 src --memory-limit 256M",
		"phpcs": "vendor/bin/phpcs src --standard=phpcs.xml",
		"phpmd": "vendor/bin/phpmd src/ text phpmd.xml",
		"test": [
			"@phpunit",
			"@phpstan",
			"@phpcs",
			"@phpmd"
		]
	},

	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/PhpGt"
		}
	]
}
